pipeline {
    agent any

    environment {
        SSH_CRED = 'node-app-key-deploy'
        SERVER_IP = '52.87.185.158'
        REMOTE_USER = 'ubuntu'
        WEB_DIR = '/var/www/html'
    }

    stages {

        stage('Deploy Website to Apache Server') {
            steps {
                sshagent(credentials: ["${SSH_CRED}"]) {
                    sh '''
                        echo "Cleaning old website files..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "
                            sudo rm -rf ${WEB_DIR}/*
                        "

                        echo "Uploading website files to EC2 /tmp directory..."
                        scp -o StrictHostKeyChecking=no -r \
                        index.html \
                        about.html \
                        contact.html \
                        portfolio-details.html \
                        portfolio.html \
                        resume.html \
                        services.html \
                        starter-page.html \
                        assets \
                        forms \
                        ${REMOTE_USER}@${SERVER_IP}:/tmp/

                        echo "Copying files from /tmp to Apache web directory..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "
                            sudo cp -r \
                            /tmp/index.html \
                            /tmp/about.html \
                            /tmp/contact.html \
                            /tmp/portfolio-details.html \
                            /tmp/portfolio.html \
                            /tmp/resume.html \
                            /tmp/services.html \
                            /tmp/starter-page.html \
                            /tmp/assets \
                            /tmp/forms \
                            ${WEB_DIR}/
                        "

                        echo "Deployment completed successfully!"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Website deployed successfully to Apache Server."
        }

        failure {
            echo "Deployment failed. Check Jenkins console logs."
        }
    }
}